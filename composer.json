{
    "name": "altrntv/sms-aero",
    "description": "SMS AERO Notifications channel for Laravel.",
    "keywords": ["laravel", "notifications", "smsaero", "SMS AERO"],
    "homepage": "https://github.com/altrntv/sms-aero",
    "license": "MIT",
    "authors": [
        {
            "name": "Pavel Dykin",
            "email": "sssecularization@gmail.com",
            "homepage": "https://github.com/altrntv",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.3",
        "illuminate/http": "^11.0|^12.0|^13.0",
        "illuminate/notifications": "^11.0|^12.0|^13.0",
        "illuminate/support": "^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "mockery/mockery": "^1.0",
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "pestphp/pest": "^2.0|^3.0|^4.0",
        "pestphp/pest-plugin-laravel": "^2.0|^3.0|^4.0"
    },
    "autoload": {
        "psr-4": {
            "NotificationChannels\\SmsAero\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "NotificationChannels\\SmsAero\\Tests\\": "tests"
        }
    },
    "scripts": {
        "test": "vendor/bin/pest",
        "test:coverage": "vendor/bin/pest --coverage"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "NotificationChannels\\SmsAero\\SmsAeroServiceProvider"
            ]
        }
    }
}
